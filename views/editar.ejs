<script>

const params = new URLSearchParams(window.location.search)
const id = params.get("id")

fetch("/alumnos/"+id)
.then(res=>res.json())
.then(a=>{

// 🔥 YA NO data[0]
// 🔥 YA ES OBJETO

num_control.value = a.num_control ?? ''
nombre.value = a.nombre ?? ''
primer_ap.value = a.primer_ap ?? ''
segundo_ap.value = a.segundo_ap ?? ''
fecha_nac.value = a.fecha_nac ? a.fecha_nac.split('T')[0] : ''
semestre.value = a.semestre ?? ''
carrera.value = a.carrera ?? ''

})

document.getElementById("formEditar").addEventListener("submit",function(e){

e.preventDefault()

fetch("/alumnos/"+id,{
method:"POST",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({

num_control:num_control.value,
nombre:nombre.value,
primer_ap:primer_ap.value,
segundo_ap:segundo_ap.value,
fecha_nac:fecha_nac.value,
semestre:semestre.value,
carrera:carrera.value

})
})

.then(()=>{
alert("Alumno actualizado")
window.location="/"
})

})

</script>