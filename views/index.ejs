<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<title>Sistema de Alumnos</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
body{
background:#f4f6f9;
}
.card-box{
background:white;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.1);
padding:25px;
}
.titulo{
font-weight:600;
}
</style>
</head>

<body>

<nav class="navbar navbar-dark bg-primary">
<div class="container">
<a class="navbar-brand" href="/">Sistema de Alumnos</a>

<a href="/altas" class="btn btn-success">
<i class="bi bi-person-plus"></i> Nuevo
</a>
</div>
</nav>

<div class="container mt-5">
<div class="card-box">

<h3 class="titulo mb-3">Listado de Alumnos</h3>

<input type="text" id="buscarAlumno" class="form-control mb-3" placeholder="Buscar...">

<div id="tabla_alumnos"></div>

</div>
</div>

<script>

// TABLA
function mostrarTabla(data){

let html = `
<table class="table table-bordered">
<thead class="table-dark">
<tr>
<th>Control</th>
<th>Nombre</th>
<th>Acciones</th>
</tr>
</thead>
<tbody>
`;

data.forEach(a=>{
html += `
<tr>
<td>${a.num_control}</td>
<td>${a.nombre}</td>
<td>

<a href="/consulta?id=${a.num_control}" class="btn btn-info btn-sm">
Consultar
</a>

<a href="/editar?id=${a.num_control}" class="btn btn-warning btn-sm">
Editar
</a>

<button class="btn btn-danger btn-sm"
onclick="eliminarAlumno('${a.num_control}')">
Eliminar
</button>

</td>
</tr>
`;
});

html += "</tbody></table>";

document.getElementById("tabla_alumnos").innerHTML = html;
}

// CARGAR
function cargarAlumnos(){
fetch("/alumnos")
.then(res => res.json())
.then(data => mostrarTabla(data));
}

// ELIMINAR
function eliminarAlumno(id){

Swal.fire({
title:"¿Eliminar?",
icon:"warning",
showCancelButton:true
}).then(r=>{

if(r.isConfirmed){

fetch("/alumnos/"+id,{
method:"DELETE"
})
.then(()=>cargarAlumnos());

}

});

}

// BUSCAR
document.getElementById("buscarAlumno").addEventListener("keyup",function(){

let texto = this.value;

if(texto === ""){
cargarAlumnos();
return;
}

fetch("/alumnos/buscar?q="+texto)
.then(res=>res.json())
.then(data=>mostrarTabla(data));

});

cargarAlumnos();

</script>

</body>
</html>