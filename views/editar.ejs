<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<title>Editar Alumno</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

<style>

body{
background:#f4f6f9;
}

.card-box{
background:white;
padding:35px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<nav class="navbar navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand" href="/">
<i class="bi bi-mortarboard-fill"></i>
Sistema de Alumnos
</a>

</div>

</nav>

<div class="container mt-5">

<div class="card-box">

<h3 class="text-warning mb-4">

<i class="bi bi-pencil-square"></i>
Editar Alumno

</h3>

<form id="formEditar">

<div class="row">

<div class="col-md-4 mb-3">
<label class="form-label">Número de Control</label>
<input id="num_control" class="form-control" readonly>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Nombre</label>
<input id="nombre" class="form-control">
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Primer Apellido</label>
<input id="primer_ap" class="form-control">
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Segundo Apellido</label>
<input id="segundo_ap" class="form-control">
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Fecha Nacimiento</label>
<input id="fecha_nac" type="date" class="form-control">
</div>

<div class="col-md-2 mb-3">
<label class="form-label">Semestre</label>
<input id="semestre" class="form-control">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Carrera</label>
<input id="carrera" class="form-control">
</div>

</div>

<button class="btn btn-success">
<i class="bi bi-save"></i>
Guardar Cambios
</button>

<a href="/" class="btn btn-secondary">
Cancelar
</a>

</form>

</div>

</div>

<script>

const params = new URLSearchParams(window.location.search)
const id = params.get("id")

fetch("/alumnos/"+id)

.then(res=>res.json())

.then(data=>{

let a=data[0]

num_control.value=a.NumControl
nombre.value=a.Nombre
primer_ap.value=a.PrimerAp
segundo_ap.value=a.SegundoAp
fecha_nac.value=a.FechaNac
semestre.value=a.Semestre
carrera.value=a.Carrera

})

document.getElementById("formEditar").addEventListener("submit",function(e){

e.preventDefault()

fetch("/alumnos/"+id,{
method:"POST",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({

num_control:num_control.value,
nombre:nombre.value,
primer_ap:primer_ap.value,
segundo_ap:segundo_ap.value,
fecha_nac:fecha_nac.value,
semestre:semestre.value,
carrera:carrera.value

})
})

.then(()=>{

alert("Alumno actualizado")
window.location="/"

})

})

</script>

</body>
</html>