<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<title>Nuevo Alumno</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

<style>

body{
background:#f4f6f9;
}

.card-box{
background:white;
padding:35px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<nav class="navbar navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand" href="/">
<i class="bi bi-mortarboard-fill"></i>
Sistema de Alumnos
</a>

</div>

</nav>

<div class="container mt-5">

<div class="card-box">

<h3 class="mb-4 text-primary">

<i class="bi bi-person-plus"></i>
Registrar Alumno

</h3>

<form action="/alumnos" method="POST">

<div class="row">

<div class="col-md-4 mb-3">
<label class="form-label">Número de Control</label>
<input name="num_control" class="form-control" required>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Nombre</label>
<input name="nombre" class="form-control" required>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Primer Apellido</label>
<input name="primer_ap" class="form-control" required>
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Segundo Apellido</label>
<input name="segundo_ap" class="form-control">
</div>

<div class="col-md-4 mb-3">
<label class="form-label">Fecha de Nacimiento</label>
<input name="fecha_nac" type="date" class="form-control">
</div>

<div class="col-md-2 mb-3">
<label class="form-label">Semestre</label>
<input name="semestre" class="form-control">
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Carrera</label>
<input name="carrera" class="form-control">
</div>

</div>

<button class="btn btn-success">
<i class="bi bi-save"></i>
Guardar
</button>

<a href="/" class="btn btn-secondary">
Cancelar
</a>

</form>

</div>

</div>

</body>
</html>