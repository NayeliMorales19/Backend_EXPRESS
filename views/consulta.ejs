<script>

window.addEventListener("DOMContentLoaded", () => {

const params = new URLSearchParams(window.location.search)
const id = params.get("id")

const nc = document.getElementById("nc")
const nombre = document.getElementById("nombre")
const ap1 = document.getElementById("ap1")
const ap2 = document.getElementById("ap2")
const fecha = document.getElementById("fecha")
const semestre = document.getElementById("semestre")
const carrera = document.getElementById("carrera")

fetch("/alumnos/" + id)
.then(res => res.json())
.then(a => {

nc.innerText = a.num_control ?? ''
nombre.innerText = a.nombre ?? ''
ap1.innerText = a.primer_ap ?? ''
ap2.innerText = a.segundo_ap ?? ''
fecha.innerText = a.fecha_nac ?? ''
semestre.innerText = a.semestre ?? ''
carrera.innerText = a.carrera ?? ''

})

})

</script>