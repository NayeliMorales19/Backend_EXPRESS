<!DOCTYPE html>
<html lang="es">

<head>

<meta charset="UTF-8">
<title>Detalle Alumno</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">

<style>

body{
background:#f4f6f9;
}

</style>

</head>

<body>

<nav class="navbar navbar-dark bg-primary">

<div class="container">

<a class="navbar-brand" href="/">
<i class="bi bi-mortarboard-fill"></i>
Sistema de Alumnos
</a>

</div>

</nav>

<div class="container mt-5">

<div class="card shadow-lg">

<div class="card-header bg-primary text-white">

<h5>

<i class="bi bi-person-vcard"></i>
Información del Alumno

</h5>

</div>

<div class="card-body">

<table class="table table-striped">

<tr>
<th>NumControl</th>
<td id="nc"></td>
</tr>

<tr>
<th>Nombre</th>
<td id="nombre"></td>
</tr>

<tr>
<th>Primer Apellido</th>
<td id="ap1"></td>
</tr>

<tr>
<th>Segundo Apellido</th>
<td id="ap2"></td>
</tr>

<tr>
<th>Fecha Nacimiento</th>
<td id="fecha"></td>
</tr>

<tr>
<th>Semestre</th>
<td id="semestre"></td>
</tr>

<tr>
<th>Carrera</th>
<td id="carrera"></td>
</tr>

</table>

<a href="/" class="btn btn-primary">

<i class="bi bi-arrow-left"></i>
Regresar

</a>

</div>

</div>

</div>

<script>

const params = new URLSearchParams(window.location.search)

const id = params.get("id")

fetch("/alumnos/" + id)

.then(res => res.json())

.then(data => {

let alumno = data[0]

document.getElementById("nc").innerText = alumno.NumControl
document.getElementById("nombre").innerText = alumno.Nombre
document.getElementById("ap1").innerText = alumno.PrimerAp
document.getElementById("ap2").innerText = alumno.SegundoAp
document.getElementById("fecha").innerText = alumno.FechaNac
document.getElementById("semestre").innerText = alumno.Semestre
document.getElementById("carrera").innerText = alumno.Carrera

})

</script>

</body>
</html>