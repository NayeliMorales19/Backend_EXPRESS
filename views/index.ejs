<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="UTF-8">
<title>Sistema de Alumnos</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h3>Listado de Alumnos</h3>

<a href="/altas" class="btn btn-success mb-3">Nuevo</a>

<table class="table" id="tabla"></table>

</div>

<script>

function cargar(){

fetch("/alumnos")
.then(res=>res.json())
.then(data=>{

if(!Array.isArray(data)){
console.error("Error:", data);
return;
}

let html=`
<tr>
<th>Num</th>
<th>Nombre</th>
<th>Acciones</th>
</tr>
`;

data.forEach(a=>{
html+=`
<tr>
<td>${a.num_control}</td>
<td>${a.nombre}</td>
<td>
<button onclick="eliminar('${a.num_control}')">Eliminar</button>
</td>
</tr>
`;
});

document.getElementById("tabla").innerHTML=html;

});

}

function eliminar(id){

fetch("/alumnos/eliminar/"+id,{method:"POST"})
.then(()=>cargar())

}

cargar();

</script>

</body>
</html>