<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Consulta Alumno</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
background: linear-gradient(135deg,#4e73df,#1cc88a);
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
}

.card-custom{
border:none;
border-radius:15px;
box-shadow:0 15px 35px rgba(0,0,0,0.2);
padding:30px;
}

.label{
font-weight:600;
color:#555;
}

.valor{
font-size:18px;
color:#222;
}
</style>

</head>

<body>

<div class="card card-custom col-md-6">

<h3 class="text-center mb-4 text-primary">👤 Consulta de Alumno</h3>

<div class="mb-3">
<span class="label">Num Control:</span><br>
<span id="nc" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Nombre:</span><br>
<span id="nombre" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Primer Apellido:</span><br>
<span id="ap1" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Segundo Apellido:</span><br>
<span id="ap2" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Fecha:</span><br>
<span id="fecha" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Semestre:</span><br>
<span id="semestre" class="valor"></span>
</div>

<div class="mb-3">
<span class="label">Carrera:</span><br>
<span id="carrera" class="valor"></span>
</div>

<a href="/" class="btn btn-primary w-100 mt-3">⬅ Volver</a>

</div>

<script>

const id = new URLSearchParams(window.location.search).get("id");

if(!id){
alert("ID no encontrado");
window.location="/";
}

fetch("/alumnos/"+id)
.then(res => res.json())
.then(a => {

document.getElementById("nc").innerText = a.num_control || '';
document.getElementById("nombre").innerText = a.nombre || '';
document.getElementById("ap1").innerText = a.primer_ap || '';
document.getElementById("ap2").innerText = a.segundo_ap || '';
document.getElementById("fecha").innerText = a.fecha_nac ? a.fecha_nac.substring(0,10) : '';
document.getElementById("semestre").innerText = a.semestre || '';
document.getElementById("carrera").innerText = a.carrera || '';

})
.catch(()=>{
alert("Error al cargar datos");
});

</script>

</body>
</html>