<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Editar Alumno</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
background: linear-gradient(135deg,#36b9cc,#4e73df);
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
}

.card-custom{
border:none;
border-radius:15px;
box-shadow:0 15px 35px rgba(0,0,0,0.2);
padding:30px;
width:400px;
}

input{
border-radius:10px !important;
}

button{
border-radius:10px !important;
}
</style>

</head>

<body>

<div class="card card-custom">

<h3 class="text-center mb-4 text-primary">✏ Editar Alumno</h3>

<form id="formEditar">

<input id="num_control" class="form-control mb-3" readonly placeholder="Num Control">

<input id="nombre" class="form-control mb-3" placeholder="Nombre">

<input id="primer_ap" class="form-control mb-3" placeholder="Primer Apellido">

<input id="segundo_ap" class="form-control mb-3" placeholder="Segundo Apellido">

<input id="fecha_nac" type="date" class="form-control mb-3">

<input id="semestre" class="form-control mb-3" placeholder="Semestre">

<input id="carrera" class="form-control mb-3" placeholder="Carrera">

<button class="btn btn-success w-100">💾 Guardar Cambios</button>

<a href="/" class="btn btn-secondary w-100 mt-2">⬅ Volver</a>

</form>

</div>

<script>

const id = new URLSearchParams(window.location.search).get("id");

if(!id){
alert("ID no encontrado");
window.location="/";
}

// CARGAR DATOS
fetch("/alumnos/"+id)
.then(res => res.json())
.then(a => {

document.getElementById("num_control").value = a.num_control || '';
document.getElementById("nombre").value = a.nombre || '';
document.getElementById("primer_ap").value = a.primer_ap || '';
document.getElementById("segundo_ap").value = a.segundo_ap || '';
document.getElementById("fecha_nac").value = a.fecha_nac ? a.fecha_nac.substring(0,10) : '';
document.getElementById("semestre").value = a.semestre || '';
document.getElementById("carrera").value = a.carrera || '';

});

// ACTUALIZAR
document.getElementById("formEditar").addEventListener("submit", function(e){

e.preventDefault();

fetch("/alumnos/"+id,{
method:"PUT",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({
num_control:document.getElementById("num_control").value,
nombre:document.getElementById("nombre").value,
primer_ap:document.getElementById("primer_ap").value,
segundo_ap:document.getElementById("segundo_ap").value,
fecha_nac:document.getElementById("fecha_nac").value,
semestre:document.getElementById("semestre").value,
carrera:document.getElementById("carrera").value
})
})
.then(()=>{
alert("Actualizado correctamente");
window.location="/";
});

});

</script>

</body>
</html>